# Database Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# LLM Configuration
# Set LLM_PROVIDER to either 'ollama' or 'openai'
LLM_PROVIDER=ollama
LLM_MODEL=mistral
LLM_TEMPERATURE=0.0

# Ollama Specific
OLLAMA_URL=http://localhost:11434/api/generate

# OpenAI Specific
OPENAI_API_KEY=your_openai_api_key_here
